# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Cloudflare (required for scripts/setup-cloudflare.sh and remote deploy)
# Create token: Dashboard → My Profile → API Tokens → Edit Cloudflare Workers (extend with D1, R2, KV, Queues Edit)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# After first deploy, set APP_URL / BETTER_AUTH_URL to your workers.dev URL

# SEC EDGAR (required — must include contact email per SEC policy)
SEC_USER_AGENT=13F-Analyzer contact@yourdomain.com

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxx
STRIPE_API_METER_ID=meter_xxxxxxxx
STRIPE_AI_TOKENS_METER_ID=meter_xxxxxxxx

# Admin backfill endpoint protection
ADMIN_SECRET=change-me-in-production
