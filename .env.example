# HoldingsKit — Agent-first SEC 13F API

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=51f97220012f6789ddb53f237d86b13c

# SEC EDGAR (required — must include contact email per SEC policy)
SEC_USER_AGENT=HoldingsKit contact@yourdomain.com

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email verification (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=HoldingsKit <noreply@oktangle.com>

# MPP — primary payment for agents (https://mpp.dev)
MPP_SECRET_KEY=
MPP_RECIPIENT=0x...
MPP_CURRENCY=0x20c0000000000000000000000000000000000000
MPP_PRICE_QUERY=0.01
MPP_PRICE_ANALYZE=0.00001

# Stripe — secondary payment for humans (Pro subscription)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxx
STRIPE_API_METER_ID=meter_xxxxxxxx
STRIPE_AI_TOKENS_METER_ID=meter_xxxxxxxx

# Admin backfill endpoint protection
ADMIN_SECRET=change-me-in-production

# Market data — Yahoo Finance (unofficial, no key required)
# Optional: FINNHUB_API_KEY for future symbol resolution fallback
# FINNHUB_API_KEY=

# SEO — optional search engine verification (set after registering in webmaster tools)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
OPENAI_PLUGIN_VERIFICATION=
