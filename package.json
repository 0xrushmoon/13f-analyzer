{
  "name": "holdingskit",
  "version": "0.2.0",
  "description": "HoldingsKit — Agent-first SEC Form 13F-HR API with MPP payments on Cloudflare Workers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xrushmoon/holdingskit.git"
  },
  "bugs": {
    "url": "https://github.com/0xrushmoon/holdingskit/issues"
  },
  "homepage": "https://github.com/0xrushmoon/holdingskit#readme",
  "keywords": [
    "13f",
    "sec-edgar",
    "institutional-holdings",
    "cloudflare-workers",
    "nextjs",
    "deepseek",
    "open-source"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "i18n:check": "node scripts/check-i18n.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply 13f-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply 13f-db --remote",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --var APP_URL:http://localhost:8787 --var BETTER_AUTH_URL:http://localhost:8787",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types",
    "ingest:dev": "wrangler dev src/workers/ingestion.ts --config wrangler.ingestion.jsonc",
    "scraper:dev": "wrangler dev src/workers/scraper.ts --config wrangler.scraper.jsonc",
    "setup:cf": "bash scripts/setup-cloudflare.sh",
    "deploy:ingestion": "wrangler deploy --config wrangler.ingestion.jsonc",
    "deploy:scraper": "wrangler deploy --config wrangler.scraper.jsonc",
    "deploy:all": "bash scripts/deploy-all.sh",
    "resync:seed": "node scripts/resync-seed.mjs",
    "resync:remote": "node scripts/run-resync-remote.mjs",
    "cleanup:remote": "node scripts/cleanup-remote.mjs",
    "enqueue:missing": "node scripts/enqueue-missing.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "better-auth": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.0.9",
    "lucide-react": "^0.475.0",
    "mppx": "^0.8.4",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "jiti": "^2.7.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "wrangler": "^4.0.0"
  }
}
